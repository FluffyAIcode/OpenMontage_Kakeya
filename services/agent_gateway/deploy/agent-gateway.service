# systemd unit for the OpenMontage Agent Gateway.
#   sudo cp services/agent_gateway/deploy/agent-gateway.service /etc/systemd/system/
#   sudo systemctl daemon-reload && sudo systemctl enable --now agent-gateway
# Edit User/WorkingDirectory/Environment for your host.
[Unit]
Description=OpenMontage Agent Gateway (public video API at kekaye.ai)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/openmontage
# The distributed-WAN workers the gateway drives (CUDA local + Mac MLX via forwarder).
Environment=WAN_WORKERS=127.0.0.1:50051,127.0.0.1:55051
# Set a secret to require X-API-Key on POST /v1/videos (recommended for a public domain).
Environment=AGENT_GATEWAY_API_KEY=
Environment=AGENT_GATEWAY_JOBS_DIR=/opt/openmontage/projects/_gateway_jobs
ExecStart=/usr/bin/python3 services/agent_gateway/server.py --host 127.0.0.1 --port 8088
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
